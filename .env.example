# Required
SECRET_KEY=change-this-to-a-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional — enables Facebook login
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Optional — enables AI features (chat, modify recipe, generate meal plan)
GEMINI_API_KEY=
# Optional — override the default Gemini model
# GEMINI_MODEL=gemini-3-flash-preview

# Production: OAuth redirect-URI base, e.g. https://meal-planner.example.com
# Also used as the trusted origin for the CSRF check.
BASE_URL=

# Optional — defaults to ./mealplanner.db (Docker: /data/mealplanner.db)
# DATABASE_PATH=

# Set to "production" to disable debug mode and enforce secure session cookies
FLASK_ENV=

# Override the listening port (default 5001)
# PORT=

# E2E test harness only — exposes /test/login and /test/reset.
# NEVER set this in production.
# FLASK_TEST_MODE=1
